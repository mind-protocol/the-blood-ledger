  "chronicle": [
    {
      "id": "chron_1",
      "day": 1,
      "location": "The South",
      "content": "We set out. Aldric swore his oath at the fire. I told him about Edmund, about what was taken. He listened. He didn't judge.",
      "isPlayerWritten": false
    },
    {
      "id": "chron_5",
      "day": 5,
      "location": "The Midlands",
      "content": "Passed through lands held by Earl Edwin. Norman patrols everywhere. We kept to the woods.",
      "isPlayerWritten": false
    },
    {
      "id": "chron_10",
      "day": 10,
      "location": "Thornwick",
      "content": "The village was half-empty. The Harrying's mark. Thin faces watched us pass. Aldric wouldn't look at them.",
      "isPlayerWritten": false
    },
    {
      "id": "chron_12",
      "day": 12,
      "location": "The North",
      "content": "Three days from York now. Edmund is close. I can feel it.",
      "isPlayerWritten": false
    }
